{
  "title": "ML Service Dashboard",
  "uid": "ml-service-001",
  "panels": [
    {
      "type": "timeseries",
      "title": "Requests per second",
      "gridPos": {"x": 0, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "rate(ml_requests_total[1m])", "legendFormat": "req/s"}]
    },
    {
      "type": "timeseries",
      "title": "P95 Latency (seconds)",
      "gridPos": {"x": 12, "y": 0, "w": 12, "h": 8},
      "targets": [{"expr": "histogram_quantile(0.95, rate(ml_request_latency_seconds_bucket[5m]))", "legendFormat": "p95"}]
    },
    {
      "type": "stat",
      "title": "Total Requests",
      "gridPos": {"x": 0, "y": 8, "w": 6, "h": 4},
      "targets": [{"expr": "ml_requests_total"}]
    },
    {
      "type": "stat",
      "title": "Total Errors",
      "gridPos": {"x": 6, "y": 8, "w": 6, "h": 4},
      "targets": [{"expr": "ml_request_errors_total"}]
    }
  ],
  "schemaVersion": 38,
  "version": 1,
  "refresh": "10s"
}